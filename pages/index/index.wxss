.container {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 40rpx;
  box-sizing: border-box;
  overflow: hidden;
  background: linear-gradient(180deg, #0a0a1a 0%, #14142e 30%, #1a1a3e 60%, #1e1830 100%);
}

/* === 顶部光晕 === */
.top-glow {
  position: absolute;
  top: -100rpx;
  width: 600rpx;
  height: 300rpx;
  background: radial-gradient(ellipse, rgba(150, 180, 255, 0.08) 0%, transparent 70%);
  pointer-events: none;
}

/* === 灵气粒子 === */
.particle-layer {
  position: absolute;
  width: 100%;
  height: 100%;
  pointer-events: none;
  overflow: hidden;
}

.particle {
  position: absolute;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(180, 220, 255, 0.6), transparent);
  animation: float-up linear infinite;
}

.p1 { width: 6rpx; height: 6rpx; left: 10%; bottom: -10%; animation-duration: 8s; animation-delay: 0s; }
.p2 { width: 4rpx; height: 4rpx; left: 25%; bottom: -10%; animation-duration: 10s; animation-delay: 1s; }
.p3 { width: 8rpx; height: 8rpx; left: 40%; bottom: -10%; animation-duration: 7s; animation-delay: 3s; }
.p4 { width: 3rpx; height: 3rpx; left: 55%; bottom: -10%; animation-duration: 12s; animation-delay: 0.5s; }
.p5 { width: 5rpx; height: 5rpx; left: 70%; bottom: -10%; animation-duration: 9s; animation-delay: 2s; }
.p6 { width: 7rpx; height: 7rpx; left: 82%; bottom: -10%; animation-duration: 11s; animation-delay: 4s; }
.p7 { width: 4rpx; height: 4rpx; left: 15%; bottom: -10%; animation-duration: 13s; animation-delay: 1.5s; }
.p8 { width: 6rpx; height: 6rpx; left: 90%; bottom: -10%; animation-duration: 9s; animation-delay: 3.5s; }

@keyframes float-up {
  0% { transform: translateY(0) scale(1); opacity: 0; }
  10% { opacity: 1; }
  90% { opacity: 0.6; }
  100% { transform: translateY(-110vh) scale(1.5); opacity: 0; }
}

/* === 背景云 === */
.bg-cloud {
  position: absolute;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(200, 215, 240, 0.04), transparent);
  pointer-events: none;
  animation: cloud-drift linear infinite;
}

.c1 {
  width: 400rpx; height: 80rpx;
  top: 25%; left: -10%;
  animation-duration: 25s;
}
.c2 {
  width: 500rpx; height: 100rpx;
  top: 45%; left: 20%;
  animation-duration: 35s;
  animation-delay: -10s;
}
.c3 {
  width: 350rpx; height: 70rpx;
  top: 60%; left: -5%;
  animation-duration: 30s;
  animation-delay: -5s;
}

@keyframes cloud-drift {
  0% { transform: translateX(0); opacity: 0; }
  10% { opacity: 1; }
  90% { opacity: 0.6; }
  100% { transform: translateX(120vw); opacity: 0; }
}

/* === 标题区域 === */
.title-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 1;
  margin-bottom: 40rpx;
}

/* 剑图标 */
.sword-icon {
  position: relative;
  width: 100rpx;
  height: 180rpx;
  margin-bottom: 30rpx;
}

.sword-blade {
  position: absolute;
  top: 0;
  left: 44rpx;
  width: 12rpx;
  height: 110rpx;
  background: linear-gradient(180deg, #b8c8e0, #7a8aa0);
  border-radius: 2rpx;
  box-shadow: 0 0 20rpx rgba(180, 200, 255, 0.3);
  animation: sword-gleam 2s ease-in-out infinite alternate;
}

.sword-guard {
  position: absolute;
  top: 108rpx;
  left: 28rpx;
  width: 44rpx;
  height: 8rpx;
  background: linear-gradient(90deg, #5a4030, #8a6a50, #5a4030);
  border-radius: 2rpx;
}

.sword-handle {
  position: absolute;
  top: 116rpx;
  left: 46rpx;
  width: 8rpx;
  height: 30rpx;
  background: linear-gradient(180deg, #6a5a4a, #4a3a2a);
  border-radius: 2rpx;
}

.sword-glow {
  position: absolute;
  top: 30rpx;
  left: 35rpx;
  width: 30rpx;
  height: 60rpx;
  background: radial-gradient(ellipse, rgba(180, 200, 255, 0.15), transparent);
  pointer-events: none;
  animation: glow-pulse 2s ease-in-out infinite alternate;
}

@keyframes sword-gleam {
  0% { box-shadow: 0 0 20rpx rgba(180, 200, 255, 0.2); }
  100% { box-shadow: 0 0 40rpx rgba(180, 200, 255, 0.5); }
}

@keyframes glow-pulse {
  0% { transform: scale(1); opacity: 0.5; }
  100% { transform: scale(1.3); opacity: 1; }
}

.title-main {
  font-size: 76rpx;
  color: #e8d5b7;
  letter-spacing: 28rpx;
  text-shadow:
    0 0 40rpx rgba(232, 213, 183, 0.3),
    0 4rpx 8rpx rgba(0, 0, 0, 0.3);
  font-weight: bold;
}

.title-sub {
  font-size: 26rpx;
  color: rgba(200, 215, 240, 0.5);
  letter-spacing: 12rpx;
  margin-top: 16rpx;
}

.deco-line {
  width: 240rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(200, 215, 240, 0.3), transparent);
  margin-top: 24rpx;
  margin-bottom: 16rpx;
}

.sub-text {
  font-size: 22rpx;
  color: rgba(200, 215, 240, 0.35);
  letter-spacing: 6rpx;
}

/* === 最高分 === */
.high-score {
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 1;
  margin-bottom: 60rpx;
}

.score-label {
  font-size: 24rpx;
  color: rgba(200, 215, 240, 0.5);
  letter-spacing: 6rpx;
}

.score-value {
  font-size: 72rpx;
  color: #ffd700;
  font-weight: bold;
  text-shadow:
    0 0 30rpx rgba(255, 215, 0, 0.3),
    0 0 60rpx rgba(255, 215, 0, 0.1);
}

/* === 开始按钮 === */
.btn-area {
  z-index: 1;
}

.btn-start {
  padding: 26rpx 110rpx;
  background: linear-gradient(135deg,
    rgba(60, 50, 90, 0.8),
    rgba(90, 75, 120, 0.8)
  );
  border-radius: 50rpx;
  border: 1px solid rgba(200, 215, 240, 0.15);
  box-shadow:
    0 8rpx 32rpx rgba(60, 50, 90, 0.4),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  transition: transform 0.2s;
  position: relative;
  overflow: hidden;
}

.btn-start::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle at 30% 50%, rgba(180, 200, 255, 0.05), transparent 60%);
  pointer-events: none;
}

.btn-text {
  font-size: 34rpx;
  color: #e8d5b7;
  letter-spacing: 12rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.btn-start:active {
  transform: scale(0.95);
  background: linear-gradient(135deg,
    rgba(70, 60, 100, 0.9),
    rgba(100, 85, 130, 0.9)
  );
}

/* === 底部 === */
.footer {
  position: absolute;
  bottom: 60rpx;
  z-index: 1;
}

.footer-text {
  font-size: 22rpx;
  color: rgba(200, 215, 240, 0.2);
  letter-spacing: 6rpx;
}
