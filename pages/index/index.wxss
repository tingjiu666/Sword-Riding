.container {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 40rpx;
  box-sizing: border-box;
  overflow: hidden;
  background: linear-gradient(175deg, #1a0f08 0%, #221408 15%, #2e1c0d 35%, #1f1409 60%, #150c05 100%);
}

/* === 水墨飞溅 === */
.ink-bg-layer {
  position: absolute;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.ink-splash {
  position: absolute;
  border-radius: 50%;
  filter: blur(40rpx);
}

.i1 { width: 300rpx; height: 300rpx; left: 10%; top: 20%;
  background: radial-gradient(circle, rgba(60, 35, 20, 0.18), transparent); }
.i2 { width: 400rpx; height: 400rpx; right: -10%; top: 40%;
  background: radial-gradient(circle, rgba(50, 28, 15, 0.14), transparent); }
.i3 { width: 250rpx; height: 250rpx; left: 40%; bottom: 20%;
  background: radial-gradient(circle, rgba(55, 30, 18, 0.12), transparent); }
.i4 { width: 350rpx; height: 350rpx; left: -5%; bottom: 10%;
  background: radial-gradient(circle, rgba(45, 25, 12, 0.15), transparent); }

/* === 星空 === */
.star-layer {
  position: absolute;
  width: 100%;
  height: 55%;
  pointer-events: none;
  overflow: hidden;
}

.star {
  position: absolute;
  border-radius: 50%;
  background: rgba(220, 180, 120, 0.5);
  animation: twinkle 2.5s ease-in-out infinite alternate;
}

@keyframes twinkle {
  0% { opacity: 0.2; transform: scale(1); background: rgba(200, 160, 100, 0.4); }
  100% { opacity: 0.9; transform: scale(1.4); background: rgba(240, 210, 150, 0.6); }
}

/* === 远山剪影（水墨层次） === */
.mountain-range {
  position: absolute;
  bottom: 0;
  width: 100%;
  height: 45%;
  pointer-events: none;
}

.mountain {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
}

.m1 {
  width: 140%;
  height: 240rpx;
  background: rgba(28, 16, 8, 0.55);
  border-radius: 60% 70% 0 0;
  bottom: -40rpx;
  left: 55%;
}

.m2 {
  width: 120%;
  height: 280rpx;
  background: rgba(22, 12, 6, 0.45);
  border-radius: 55% 65% 0 0;
  bottom: 20rpx;
  left: 45%;
}

.m3 {
  width: 110%;
  height: 320rpx;
  background: rgba(18, 10, 5, 0.38);
  border-radius: 50% 55% 0 0;
  bottom: 60rpx;
}

/* === 顶部光晕 === */
.top-glow {
  position: absolute;
  top: -80rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 500rpx;
  height: 250rpx;
  background: radial-gradient(ellipse, rgba(220, 160, 80, 0.07) 0%, transparent 70%);
  pointer-events: none;
}

.top-glow2 {
  position: absolute;
  top: -20rpx;
  left: 60%;
  width: 300rpx;
  height: 180rpx;
  background: radial-gradient(ellipse, rgba(200, 140, 60, 0.05) 0%, transparent 70%);
  pointer-events: none;
}

/* === 金尘粒子 === */
.particle-layer {
  position: absolute;
  width: 100%;
  height: 100%;
  pointer-events: none;
  overflow: hidden;
}

.particle {
  position: absolute;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(220, 180, 100, 0.5), transparent);
  animation: float-up linear infinite;
}

.p1 { width: 6rpx; height: 6rpx; left: 10%; bottom: -10%; animation-duration: 10s; animation-delay: 0s; }
.p2 { width: 4rpx; height: 4rpx; left: 25%; bottom: -10%; animation-duration: 12s; animation-delay: 1.5s; }
.p3 { width: 8rpx; height: 8rpx; left: 40%; bottom: -10%; animation-duration: 9s; animation-delay: 3s; }
.p4 { width: 3rpx; height: 3rpx; left: 55%; bottom: -10%; animation-duration: 14s; animation-delay: 0.5s; }
.p5 { width: 5rpx; height: 5rpx; left: 70%; bottom: -10%; animation-duration: 11s; animation-delay: 2s; }
.p6 { width: 7rpx; height: 7rpx; left: 82%; bottom: -10%; animation-duration: 13s; animation-delay: 4s; }
.p7 { width: 4rpx; height: 4rpx; left: 15%; bottom: -10%; animation-duration: 15s; animation-delay: 1s; }
.p8 { width: 6rpx; height: 6rpx; left: 90%; bottom: -10%; animation-duration: 11s; animation-delay: 3.5s; }

@keyframes float-up {
  0% { transform: translateY(0) scale(1); opacity: 0; }
  8% { opacity: 0.9; }
  85% { opacity: 0.3; }
  100% { transform: translateY(-110vh) scale(1.6); opacity: 0; }
}

/* === 背景云霭 === */
.bg-cloud {
  position: absolute;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(160, 120, 80, 0.03), transparent);
  pointer-events: none;
  animation: cloud-drift linear infinite;
}

.c1 { width: 400rpx; height: 80rpx; top: 30%; left: -10%; animation-duration: 35s; }
.c2 { width: 500rpx; height: 100rpx; top: 50%; left: 20%; animation-duration: 45s; animation-delay: -12s; }
.c3 { width: 350rpx; height: 70rpx; top: 65%; left: -5%; animation-duration: 40s; animation-delay: -6s; }

@keyframes cloud-drift {
  0% { transform: translateX(0); opacity: 0; }
  12% { opacity: 0.7; }
  85% { opacity: 0.3; }
  100% { transform: translateX(120vw); opacity: 0; }
}

/* === 标题区域 === */
.title-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 2;
  margin-bottom: 20rpx;
}

/* === 武侠人物剪影 === */
.hero-silhouette {
  position: relative;
  width: 200rpx;
  height: 260rpx;
  margin-bottom: 16rpx;
}

/* 剑气光环 */
.hero-ring {
  position: absolute;
  top: -10rpx;
  left: 18rpx;
  width: 160rpx;
  height: 160rpx;
  border: 2rpx solid rgba(220, 170, 80, 0.12);
  border-radius: 50%;
  animation: ring-rotate 5s linear infinite;
}

.hero-ring2 {
  top: -20rpx;
  left: 28rpx;
  width: 140rpx;
  height: 140rpx;
  border-color: rgba(200, 150, 60, 0.08);
  animation-duration: 7s;
  animation-direction: reverse;
}

@keyframes ring-rotate {
  0% { transform: rotate(0deg) scale(1); }
  50% { transform: rotate(180deg) scale(1.08); }
  100% { transform: rotate(360deg) scale(1); }
}

/* 身体/道袍 */
.hero-body {
  position: absolute;
  top: 80rpx;
  left: 65rpx;
  width: 70rpx;
  height: 110rpx;
  background: linear-gradient(180deg, #3d2d20, #2a1d12);
  border-radius: 10rpx 10rpx 30rpx 30rpx;
}

/* 头部 */
.hero-head {
  position: absolute;
  top: 55rpx;
  left: 80rpx;
  width: 40rpx;
  height: 44rpx;
  background: #3d2d20;
  border-radius: 50%;
}

/* 发髻 */
.hero-topknot {
  position: absolute;
  top: 40rpx;
  left: 88rpx;
  width: 24rpx;
  height: 28rpx;
  background: #2a1d12;
  border-radius: 50%;
}

/* 笠帽 */
.hero-hat {
  position: absolute;
  top: 35rpx;
  left: 55rpx;
  width: 90rpx;
  height: 55rpx;
}

.hat-brim {
  position: absolute;
  bottom: 0;
  left: -5rpx;
  width: 100rpx;
  height: 16rpx;
  background: linear-gradient(180deg, #3d2d20, #2a1d12);
  border-radius: 50%;
}

.hat-crown {
  position: absolute;
  bottom: 10rpx;
  left: 14rpx;
  width: 62rpx;
  height: 35rpx;
  background: linear-gradient(180deg, #3d2d20, #332418);
  border-radius: 40rpx 40rpx 8rpx 8rpx;
}

.hat-top {
  position: absolute;
  bottom: 36rpx;
  left: 42rpx;
  width: 6rpx;
  height: 20rpx;
  background: #3d2d20;
  border-radius: 3rpx 3rpx 0 0;
}

/* 右臂持剑（前伸） */
.hero-arm-right {
  position: absolute;
  top: 92rpx;
  left: 115rpx;
  width: 60rpx;
  height: 12rpx;
  background: #3d2d20;
  border-radius: 6rpx;
  transform: rotate(-5deg);
}

/* 飞剑 */
.hero-sword {
  position: absolute;
  top: 86rpx;
  left: 160rpx;
  width: 110rpx;
  height: 16rpx;
}

.sword-blade {
  position: absolute;
  top: 2rpx;
  left: 0;
  width: 90rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #a09070, #c8b898, #a09070);
  border-radius: 1rpx;
  box-shadow: 0 0 20rpx rgba(220, 170, 80, 0.3);
  animation: blade-shimmer 2s ease-in-out infinite alternate;
}

@keyframes blade-shimmer {
  0% { box-shadow: 0 0 15rpx rgba(200, 150, 60, 0.2); }
  100% { box-shadow: 0 0 35rpx rgba(240, 190, 80, 0.45); }
}

.sword-guard {
  position: absolute;
  top: 0;
  left: 88rpx;
  width: 12rpx;
  height: 12rpx;
  background: linear-gradient(180deg, #8a6040, #5a3a20);
  border-radius: 1rpx;
}

.sword-handle {
  position: absolute;
  top: 3rpx;
  left: 98rpx;
  width: 16rpx;
  height: 6rpx;
  background: #5a3a20;
  border-radius: 1rpx;
}

/* 剑气光效 */
.sword-aura {
  position: absolute;
  top: 70rpx;
  left: 145rpx;
  width: 120rpx;
  height: 40rpx;
  background: radial-gradient(ellipse, rgba(220, 170, 80, 0.08), transparent 70%);
  animation: aura-pulse 2s ease-in-out infinite alternate;
  pointer-events: none;
}

@keyframes aura-pulse {
  0% { transform: scale(0.9); opacity: 0.4; }
  100% { transform: scale(1.15); opacity: 0.8; }
}

/* 左臂 */
.hero-arm-left {
  position: absolute;
  top: 95rpx;
  left: 40rpx;
  width: 28rpx;
  height: 10rpx;
  background: #332418;
  border-radius: 5rpx;
  transform: rotate(10deg);
}

/* 披风 */
.hero-cape {
  position: absolute;
  top: 75rpx;
  left: 35rpx;
  width: 50rpx;
  height: 130rpx;
  background: linear-gradient(180deg, #332418, #22150a);
  border-radius: 5rpx 25rpx 20rpx 10rpx;
  transform: rotate(5deg);
}

/* 衣摆飘动 */
.hero-robe {
  position: absolute;
  bottom: 22rpx;
  left: 60rpx;
  width: 80rpx;
  height: 35rpx;
  background: linear-gradient(180deg, #2a1d12, #1a0f08);
  border-radius: 0 0 15rpx 15rpx;
  animation: robe-sway 3s ease-in-out infinite alternate;
}

@keyframes robe-sway {
  0% { transform: skewX(-2deg); }
  100% { transform: skewX(2deg); }
}

/* 标题 */
.title-chinese {
  font-size: 76rpx;
  color: #d4b896;
  letter-spacing: 28rpx;
  text-shadow:
    0 0 60rpx rgba(200, 150, 80, 0.3),
    0 4rpx 12rpx rgba(0, 0, 0, 0.5);
  font-weight: bold;
  margin-bottom: 10rpx;
}

.title-sub {
  font-size: 24rpx;
  color: rgba(200, 160, 120, 0.45);
  letter-spacing: 16rpx;
}

.deco-line {
  position: relative;
  width: 240rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(200, 160, 100, 0.3), transparent);
  margin-top: 18rpx;
  margin-bottom: 12rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.deco-diamond {
  width: 8rpx;
  height: 8rpx;
  background: rgba(200, 150, 80, 0.35);
  transform: rotate(45deg);
}

.sub-text {
  font-size: 20rpx;
  color: rgba(200, 160, 120, 0.3);
  letter-spacing: 10rpx;
}

/* === 最高分 === */
.high-score {
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 2;
  margin-bottom: 35rpx;
}

.score-label {
  font-size: 22rpx;
  color: rgba(200, 160, 120, 0.4);
  letter-spacing: 12rpx;
  margin-bottom: 4rpx;
}

.score-value-wrap {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.score-value {
  font-size: 72rpx;
  color: #ffd700;
  font-weight: bold;
  text-shadow:
    0 0 40rpx rgba(255, 200, 50, 0.3),
    0 0 80rpx rgba(255, 180, 40, 0.12);
}

.score-unit {
  font-size: 24rpx;
  color: rgba(200, 160, 120, 0.35);
  letter-spacing: 4rpx;
}

.score-deco {
  width: 60rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(200, 150, 80, 0.2), transparent);
  margin-top: 8rpx;
}

/* === 开始按钮 === */
.btn-area {
  z-index: 2;
}

.btn-start {
  position: relative;
  padding: 26rpx 100rpx;
  border-radius: 50rpx;
  overflow: hidden;
  transition: transform 0.2s;
}

.btn-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, rgba(80, 55, 30, 0.88), rgba(120, 85, 45, 0.88));
  border: 1px solid rgba(200, 150, 80, 0.15);
  box-shadow:
    0 6rpx 36rpx rgba(60, 35, 15, 0.55),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.06);
  border-radius: 50rpx;
}

.btn-glow {
  position: absolute;
  top: -20%;
  left: 20%;
  width: 60%;
  height: 140%;
  background: radial-gradient(ellipse, rgba(255, 220, 150, 0.06), transparent);
  pointer-events: none;
  border-radius: 50%;
}

.btn-text {
  position: relative;
  font-size: 34rpx;
  color: #e8d0a8;
  letter-spacing: 16rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
  z-index: 1;
}

.btn-start:active {
  transform: scale(0.94);
}

.btn-start:active .btn-bg {
  background: linear-gradient(135deg, rgba(100, 70, 40, 0.92), rgba(140, 100, 55, 0.92));
}

/* === 底部 === */
.footer {
  position: absolute;
  bottom: 50rpx;
  z-index: 2;
}

.footer-text {
  font-size: 20rpx;
  color: rgba(200, 160, 120, 0.18);
  letter-spacing: 8rpx;
}
