.game-container {
  position: relative;
  width: 100vw;
  height: 100vh;
}

.game-canvas {
  width: 100vw;
  height: 100vh;
  display: block;
}

/* === 得分覆盖层 === */
.score-overlay {
  position: absolute;
  top: 80rpx;
  left: 0;
  width: 100%;
  text-align: center;
}

.score-text {
  font-size: 96rpx;
  color: rgba(220, 180, 120, 0.9);
  font-weight: bold;
  letter-spacing: 8rpx;
}

/* === 游戏结束覆盖层 === */
.game-over-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(15, 10, 5, 0.78);
}

.over-panel {
  width: 520rpx;
  padding: 56rpx 40rpx;
  background: #201810;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx solid rgba(180, 140, 100, 0.2);
}

.over-title {
  font-size: 48rpx;
  color: #d4b896;
  letter-spacing: 16rpx;
  margin-bottom: 28rpx;
}

.deco-line {
  width: 140rpx;
  height: 2rpx;
  background: rgba(180, 140, 100, 0.3);
  margin-bottom: 36rpx;
}

.score-row {
  display: flex;
  justify-content: center;
  align-items: baseline;
  margin-bottom: 18rpx;
}

.over-label {
  font-size: 28rpx;
  color: rgba(180, 140, 100, 0.5);
  letter-spacing: 6rpx;
  margin-right: 16rpx;
}

.over-score {
  font-size: 70rpx;
  color: #ffd700;
  font-weight: bold;
}

.over-highscore {
  font-size: 54rpx;
  color: #d4b896;
  font-weight: bold;
}

.record-label {
  font-size: 32rpx;
  color: #ff8a6b;
  letter-spacing: 8rpx;
  margin-bottom: 10rpx;
}

/* === 按钮 === */
.btn-restart {
  margin-top: 36rpx;
  padding: 22rpx 90rpx;
  background: #5a3d25;
  border-radius: 50rpx;
  border: 2rpx solid rgba(200, 150, 80, 0.18);
}

.btn-r-text {
  font-size: 32rpx;
  color: #d4b896;
  letter-spacing: 8rpx;
}

.btn-home {
  margin-top: 18rpx;
  padding: 14rpx 56rpx;
  border-radius: 50rpx;
  border: 1rpx solid rgba(180, 140, 100, 0.1);
}

.btn-h-text {
  font-size: 26rpx;
  color: rgba(180, 140, 100, 0.5);
  letter-spacing: 6rpx;
}
