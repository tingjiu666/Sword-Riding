.game-container {
  position: relative;
  width: 100vw;
  height: 100vh;
}

.game-canvas {
  width: 100vw;
  height: 100vh;
  display: block;
}

.score-overlay {
  position: absolute;
  top: 80rpx;
  left: 0;
  width: 100%;
  text-align: center;
  pointer-events: none;
}

.score-text {
  font-size: 96rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: bold;
  text-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.5);
  letter-spacing: 8rpx;
}

.game-over-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(8px);
}

.over-panel {
  width: 560rpx;
  padding: 60rpx 40rpx;
  background: linear-gradient(135deg, rgba(30, 25, 60, 0.95), rgba(50, 40, 80, 0.95));
  border-radius: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 1px solid rgba(232, 213, 183, 0.15);
}

.over-title {
  font-size: 48rpx;
  color: #e8d5b7;
  letter-spacing: 12rpx;
  margin-bottom: 30rpx;
  text-shadow: 0 0 20px rgba(232, 213, 183, 0.2);
}

.deco-line {
  width: 160rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #e8d5b7, transparent);
  margin-bottom: 40rpx;
}

.score-row {
  display: flex;
  justify-content: center;
  align-items: baseline;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.over-label {
  font-size: 28rpx;
  color: rgba(232, 213, 183, 0.6);
  letter-spacing: 4rpx;
}

.over-score {
  font-size: 72rpx;
  color: #ffd700;
  font-weight: bold;
  text-shadow: 0 0 20px rgba(255, 215, 0, 0.3);
}

.over-highscore {
  font-size: 56rpx;
  color: #e8d5b7;
  font-weight: bold;
}

.record-label {
  font-size: 32rpx;
  color: #ff6b6b;
  letter-spacing: 8rpx;
  text-shadow: 0 0 20px rgba(255, 107, 107, 0.4);
  animation: pulse 0.8s ease-in-out infinite alternate;
}

@keyframes pulse {
  from { opacity: 0.7; transform: scale(1); }
  to { opacity: 1; transform: scale(1.05); }
}

.btn-restart {
  margin-top: 40rpx;
  padding: 24rpx 100rpx;
  background: linear-gradient(135deg, #4a3f6b, #6b5b8a);
  border-radius: 50rpx;
  color: #e8d5b7;
  font-size: 32rpx;
  letter-spacing: 8rpx;
  box-shadow: 0 8rpx 32rpx rgba(74, 63, 107, 0.5);
}

.btn-restart:active {
  transform: scale(0.95);
}

.btn-home {
  margin-top: 20rpx;
  padding: 16rpx 60rpx;
  color: rgba(232, 213, 183, 0.5);
  font-size: 26rpx;
  letter-spacing: 4rpx;
}

.btn-home:active {
  opacity: 0.7;
}
