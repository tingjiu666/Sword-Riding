<view class="game-container">
  <canvas
    type="2d"
    id="gameCanvas"
    class="game-canvas"
    bindtap="onTap"
  ></canvas>

  <cover-view class="score-overlay" wx:if="{{!gameOver}}">
    <cover-view class="score-text">{{score}}</cover-view>
  </cover-view>

  <cover-view class="game-over-overlay" wx:if="{{gameOver}}">
    <cover-view class="over-panel">
      <cover-view class="over-title">游 戏 结 束</cover-view>
      <cover-view class="deco-line"></cover-view>
      <cover-view class="score-row">
        <cover-view class="over-label">得分</cover-view>
        <cover-view class="over-score">{{score}}</cover-view>
      </cover-view>
      <cover-view class="score-row" wx:if="{{isNewRecord}}">
        <cover-view class="record-label">新纪录!</cover-view>
      </cover-view>
      <cover-view class="score-row">
        <cover-view class="over-label">最高分</cover-view>
        <cover-view class="over-highscore">{{highScore}}</cover-view>
      </cover-view>
      <cover-view class="btn-restart" bindtap="onRestart">
        <cover-view class="btn-r-text">再 来 一 局</cover-view>
      </cover-view>
      <cover-view class="btn-home" bindtap="onHome">
        <cover-view class="btn-h-text">返回首页</cover-view>
      </cover-view>
    </cover-view>
  </cover-view>
</view>
